# ============================================================
# Grand River Basements — deployment credentials
# This file is in a PRIVATE repo — do not move to a public one
# Fill in ONE block below depending on your hosting provider
# ============================================================

# ----------------------------------------------------------
# OPTION A: Hostinger / cPanel FTP
# ----------------------------------------------------------
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_REMOTE_DIR=/public_html

# ----------------------------------------------------------
# OPTION B: Cloudflare Pages (direct upload API)
# ----------------------------------------------------------
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_PROJECT_NAME=grand-river-basements
